{
  "name": "network-master",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "data:deps": "sh scripts/run_python.sh -m pip install -r requirements-data.txt",
    "data:build": "sh scripts/run_python.sh scripts/build_exam_json.py --apply-explanation-cache",
    "data:build:cache": "sh scripts/run_python.sh scripts/build_exam_json.py --apply-explanation-cache",
    "data:build:explanations": "sh scripts/run_python.sh scripts/build_exam_json.py --with-choice-explanations --requests-per-minute 5",
    "deploy:s3": "sh scripts/deploy_s3.sh",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  }
}
